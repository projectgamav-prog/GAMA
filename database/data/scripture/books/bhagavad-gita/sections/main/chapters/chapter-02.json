          "slug": "verse-47",
          "number": "47",
          "text": "Your responsibility is in action alone, never in the fruits.",
          "sort_order": 1,
          "translations": [
            {
              "source_key": "dev-en",
              "source_name": "Development English",
              "language_code": "en",
