          "translations": [
            {
              "source_key": "dev-en",
              "source_name": "Development English",
              "language_code": "en",
              "text": "Remain balanced in success and failure; that balance is called yoga.",
              "sort_order": 1
            },
            {
              "source_key": "dev-hi",
              "source_name": "Development Hindi",
              "language_code": "hi",
              "text": "Safalta aur asafalta mein samabhav rakhna hi yoga hai.",
